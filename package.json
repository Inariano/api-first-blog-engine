{
    "name": "api-first-blog-engine",
    "version": "1.0.0",
    "description": "API-First Blog Engine with Handlebars and HTMX",
    "main": "src/server.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "test": "jest --watchAll --verbose",
        "test:coverage": "jest --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "keywords": [
        "blog",
        "api-first",
        "htmx",
        "handlebars",
        "mongodb",
        "tdd"
    ],
    "author": "Jonatas de Oliveira Souza Junior",
    "license": "MIT",
    "dependencies": {
        "cloudinary": "^2.2.0",
        "connect-mongo": "^5.1.0",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "csurf": "^1.11.0",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.2.0",
        "express-session": "^1.18.0",
        "hbs": "^4.2.0",
        "helmet": "^7.1.0",
        "htmx.org": "^1.9.12",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.4.0",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "passport": "^0.7.0",
        "passport-github2": "^0.1.12",
        "passport-google-oauth20": "^2.0.0",
        "winston": "^3.13.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "cheerio": "^1.0.0-rc.12",
        "eslint": "^8.57.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-plugin-import": "^2.29.1",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^9.2.0",
        "nodemon": "^3.1.0",
        "supertest": "^7.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "coveragePathIgnorePatterns": [
            "/node_modules/"
        ],
        "collectCoverageFrom": [
            "src/**/*.js"
        ],
        "coverageThreshold": {
            "global": {
                "branches": 100,
                "functions": 100,
                "lines": 100,
                "statements": 100
            }
        }
    }
}