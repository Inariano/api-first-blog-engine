<div id="post-content">
  <a href="/web" class="text-indigo-600 hover:text-indigo-800 mb-4 inline-block">&larr; Back to posts</a>
  <h1 class="text-4xl font-bold mb-4">{{post.title}}</h1>
  <div class="flex items-center gap-4 text-sm text-gray-500 mb-8">
    <span>By {{post.author.name}}</span>
    <span>&middot;</span>
    <time datetime="{{post.createdAt}}">{{post.createdAt}}</time>
    {{#if post.tags.length}}
      <span>&middot;</span>
      <div class="flex gap-2">
        {{#each post.tags}}
          <span class="bg-gray-100 px-2 py-1 rounded">{{this}}</span>
        {{/each}}
      </div>
    {{/if}}
  </div>
  <div class="prose max-w-none text-gray-700 leading-relaxed">
    {{post.content}}
  </div>
</div>
