<header class="bg-white shadow-sm border-b">
  <div class="container mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-indigo-600">Blog Engine</a>
    <nav class="space-x-4 flex items-center">
      <a href="/" class="text-gray-600 hover:text-indigo-600">Home</a>
      {{#if categories}}
        {{#each categories}}
          <a href="/web/categories/{{this.slug}}"
             class="bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition">
            {{this.name}}
          </a>
        {{/each}}
      {{/if}}
      {{#if user}}
        <span class="text-gray-700 text-sm font-medium">{{user.name}}</span>
        {{#if (eq user.role 'admin')}}
          <a href="/web/admin"
             class="bg-purple-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-purple-700 transition">
            Admin
          </a>
        {{/if}}
        <a href="/web/logout"
           class="text-gray-600 hover:text-indigo-600 text-sm font-medium">
          Logout
        </a>
      {{else}}
        <a href="/web/register"
           class="text-gray-600 hover:text-indigo-600 text-sm font-medium">
          Sign Up
        </a>
        <a href="/web/login"
           class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-indigo-700 transition">
          Login
        </a>
      {{/if}}
    </nav>
  </div>
</header>
