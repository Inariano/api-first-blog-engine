<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold">Categories</h1>
    <a href="/web/admin/categories/new"
       class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition">
      + New Category
    </a>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b">
        <tr>
          <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Name</th>
          <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Slug</th>
          <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Description</th>
          <th class="text-right px-6 py-3 text-sm font-medium text-gray-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        {{#each categories}}
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 font-medium">{{this.name}}</td>
            <td class="px-6 py-4 text-sm text-gray-500">{{this.slug}}</td>
            <td class="px-6 py-4 text-sm text-gray-600">{{this.description}}</td>
            <td class="px-6 py-4 text-right space-x-2">
              <a href="/web/admin/categories/{{this._id}}/edit"
                 class="text-indigo-600 hover:text-indigo-800 text-sm">Edit</a>
              <form method="POST" action="/web/admin/categories/{{this._id}}/delete" class="inline"
                    data-confirm="Delete this category?">
                {{> csrf}}
                <button type="submit" class="text-red-600 hover:text-red-800 text-sm">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
        {{#unless categories.length}}
          <tr>
            <td colspan="4" class="px-6 py-12 text-center text-gray-400">
              No categories yet.
              <a href="/web/admin/categories/new" class="text-indigo-600 hover:text-indigo-800 ml-1">
                Create your first category
              </a>
            </td>
          </tr>
        {{/unless}}
      </tbody>
    </table>
  </div>
</div>
