<div class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold">Dashboard</h1>
     <div class="flex gap-3">
       {{#if (eq user.role 'admin')}}
         <a href="/web/admin/users"
            class="bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700 transition">
           User List
         </a>
       {{/if}}
       <a href="/web/admin/categories/new"
          class="bg-emerald-600 text-white px-4 py-2 rounded-lg hover:bg-emerald-700 transition">
         + New Category
       </a>
       <a href="/web/admin/posts/new"
          class="bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition">
         + New Post
       </a>
     </div>
  </div>

  <div class="grid grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500 mb-1">Total Posts</p>
      <p class="text-3xl font-bold">{{stats.total}}</p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500 mb-1">Published</p>
      <p class="text-3xl font-bold text-green-600">{{stats.published}}</p>
    </div>
    <div class="bg-white rounded-lg shadow p-6">
      <p class="text-sm text-gray-500 mb-1">Drafts</p>
      <p class="text-3xl font-bold text-yellow-600">{{stats.drafts}}</p>
    </div>
  </div>

  <div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b">
        <tr>
          <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Title</th>
          <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Author</th>
          <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Status</th>
          <th class="text-left px-6 py-3 text-sm font-medium text-gray-500">Updated</th>
          <th class="text-right px-6 py-3 text-sm font-medium text-gray-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        {{#each posts}}
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4">
              <a href="/web/posts/{{this._id}}" class="text-indigo-600 hover:text-indigo-800 font-medium">
                {{this.title}}
              </a>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600">{{this.author.name}}</td>
            <td class="px-6 py-4">
              {{#if (eq this.status 'published')}}
                <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full">Published</span>
              {{else}}
                <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded-full">Draft</span>
              {{/if}}
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">{{this.updatedAt}}</td>
            <td class="px-6 py-4 text-right space-x-2">
              <a href="/web/admin/posts/{{this._id}}/edit"
                 class="text-indigo-600 hover:text-indigo-800 text-sm">Edit</a>
              <form method="POST" action="/web/admin/posts/{{this._id}}/toggle-status" class="inline">
                {{> csrf}}
                <button type="submit" class="text-yellow-600 hover:text-yellow-800 text-sm">
                  {{#if (eq this.status 'published')}}Unpublish{{else}}Publish{{/if}}
                </button>
              </form>
              <form method="POST" action="/web/admin/posts/{{this._id}}/delete" class="inline"
                    data-confirm="Delete this post? All comments will also be deleted.">
                {{> csrf}}
                <button type="submit" class="text-red-600 hover:text-red-800 text-sm">Delete</button>
              </form>
            </td>
          </tr>
        {{/each}}
        {{#unless posts.length}}
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-400">
              No posts yet.
              <a href="/web/admin/posts/new" class="text-indigo-600 hover:text-indigo-800 ml-1">
                Create your first post
              </a>
            </td>
          </tr>
        {{/unless}}
      </tbody>
    </table>
  </div>
</div>
